{
  "manifest_version": 3,
  "name": "Komorebi",
  "version": "0.7.1",
  "description": "Komorebi — a calm Everforest theme for the web: AI chats, mail, GitHub, Google, Drive, Docs, Cloudflare, YouTube, Bilibili, arXiv & more. Light & dark.",
  "author": "Jesse Zhang",
  "homepage_url": "https://github.com/Nagi-ovo/komorebi",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*", "https://gist.github.com/*"],
      "css": ["theme.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.google.com/search*", "https://www.google.co.uk/search*"],
      "css": ["google.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*", "https://mobile.x.com/*"],
      "css": ["x.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "css": ["chatgpt.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://claude.ai/*"],
      "css": ["claude.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "css": ["gemini.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://mail.google.com/*"],
      "css": ["gmail.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://drive.google.com/*"],
      "css": ["drive.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://docs.google.com/*"],
      "css": ["docs.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://dash.cloudflare.com/*"],
      "css": ["cloudflare.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://outlook.cloud.microsoft/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*",
        "https://outlook.live.com/*"
      ],
      "css": ["outlook.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://*.bilibili.com/*", "https://bilibili.com/*"],
      "css": ["bilibili.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.youtube.com/*", "https://m.youtube.com/*"],
      "css": ["youtube.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://arxiv.org/*", "https://www.arxiv.org/*", "https://info.arxiv.org/*"],
      "css": ["arxiv.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://grok.com/*", "https://www.grok.com/*"],
      "css": ["grok.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Komorebi",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
