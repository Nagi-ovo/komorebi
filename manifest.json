{
  "manifest_version": 3,
  "name": "Komorebi",
  "version": "0.4.1",
  "description": "Komorebi — a calm theme for GitHub, Google Search & X, based on the Everforest palette. Light & dark.",
  "author": "Jesse Zhang",
  "homepage_url": "https://github.com/Nagi-ovo/komorebi",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*", "https://gist.github.com/*"],
      "css": ["theme.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.google.com/search*", "https://www.google.co.uk/search*"],
      "css": ["google.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*", "https://mobile.x.com/*"],
      "css": ["x.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Komorebi",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
