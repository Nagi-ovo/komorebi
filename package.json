{
  "name": "komorebi",
  "version": "0.4.1",
  "description": "Komorebi — a calm theme for the web (GitHub, Google, X), based on the Everforest palette.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun run src/build.ts",
    "watch": "bun run src/build.ts --watch",
    "typecheck": "bunx tsc --noEmit",
    "zip": "cd dist && zip -r -FS ../komorebi.zip . -x '*.DS_Store'"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/chrome": "^0.1.43",
    "typescript": "^5.6.0"
  }
}
