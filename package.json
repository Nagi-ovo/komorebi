{
  "name": "gh-everforest-theme",
  "version": "0.1.0",
  "description": "Everforest theme for GitHub — a Chrome/Edge extension that restyles github.com with the warm, low-contrast Everforest palette.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun run src/build.ts",
    "watch": "bun run src/build.ts --watch",
    "typecheck": "bunx tsc --noEmit",
    "zip": "cd dist && zip -r -FS ../gh-everforest-theme.zip . -x '*.DS_Store'"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/chrome": "^0.1.43",
    "typescript": "^5.6.0"
  }
}
