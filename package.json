{
  "name": "komorebi",
  "version": "0.7.4",
  "description": "A calm Everforest color theme for the web, in matching light and dark — softer, consistent colors that are easier on the eyes.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun run src/build.ts",
    "watch": "bun run src/build.ts --watch",
    "typecheck": "bunx tsc --noEmit",
    "zip": "cd dist && zip -r -FS ../komorebi.zip . -x '*.DS_Store'"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/chrome": "^0.1.43",
    "typescript": "^5.6.0"
  }
}
